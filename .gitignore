# Manter a pasta data/ existir (gitkeep) mas nao seus conteudos CSV
!04-batch-performance/**/data/.gitkeep

# O CSV descompactado de 1m na pasta raiz data/ e gerado pelo distribute.sh
/data/transactions_1m.csv

