{
    "name": "esales/batch-performance",
    "description": "Financial transaction batch processor with intentional O(n²) bottlenecks",
    "type": "project",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "BatchProcessor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BatchProcessor\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
